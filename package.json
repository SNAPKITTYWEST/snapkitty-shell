{
  "name": "snapkitty-shell",
  "version": "0.1.0",
  "description": "SnapKitty Shell — sovereign agentic bash/shell execution framework",
  "type": "module",
  "main": "src/api/server.mjs",
  "bin": {
    "sk": "bin/sk.mjs",
    "skrun": "bin/skrun.mjs"
  },
  "scripts": {
    "start": "node src/api/server.mjs",
    "dev": "node --watch src/api/server.mjs",
    "audit": "node bin/skrun.mjs workflows/audit-repo.json",
    "cbom": "node src/crypto/cbom-report.mjs",
    "cbom:json": "node src/crypto/cbom-report.mjs --json",
    "pq:install": "npm install @noble/post-quantum",
    "test": "node --test tests/"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "fastify": "^4.28.1"
  },
  "optionalDependencies": {
    "@noble/post-quantum": "^0.2.1"
  },
  "keywords": [
    "shell",
    "bash",
    "agent",
    "agentic",
    "framework",
    "sovereign",
    "snapkitty",
    "grep",
    "workflow",
    "worm",
    "backtick"
  ],
  "license": "Apache-2.0"
}
